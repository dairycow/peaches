# IB Gateway Configuration
TWS_USERID=your_ibkr_username
TWS_PASSWORD=your_ibkr_password
TRADING_MODE=paper
TIME_ZONE=Etc/UTC
VNC_SERVER_PASSWORD=

# CoolTrader Credentials
COOLTRADER_USERNAME=your_cooltrader_username
COOLTRADER_PASSWORD=your_cooltrader_password

# Discord (optional)
SCANNERS_NOTIFICATIONS_DISCORD_WEBHOOK_URL=

# IBKR Scanner Configuration (ibind OAuth)
IBKR_SCANNER__ENABLED=false
IBKR_SCANNER__OAUTH_CONSUMER_KEY=
IBKR_SCANNER__OAUTH_ACCESS_TOKEN=
IBKR_SCANNER__OAUTH_ACCESS_TOKEN_SECRET=
IBKR_SCANNER__OAUTH_DH_PRIME=
IBKR_SCANNER__SIGNATURE_KEY_PATH=/opt/oauth_keys/signature_key.pem
IBKR_SCANNER__ENCRYPTION_KEY_PATH=/opt/oauth_keys/encryption_key.pem
IBKR_SCANNER__GAP_THRESHOLD=3.0
IBKR_SCANNER__SCAN_SCHEDULE=30 10 * * 1-5

# Optional Configuration Overrides
LOG_LEVEL=INFO
IB_GATEWAY_PORT=4004
